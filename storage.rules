rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload to products folder
    match /products/{allPaths=**} {
      allow read: if true; // Anyone can read product images/videos
      allow write: if request.auth != null; // Only authenticated users can upload
    }
    
    // Allow authenticated users to upload to reviews folder
    match /reviews/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow users to upload to their own profile folder
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
